# This is an example .env file. Rename it to .env and fill in the values for your environment variables.
LLM_API_KEY="your-llm-api-key-here"

# Optional: override the default LLM base URL and model
# LLM_BASE_URL="https://api.deepseek.com"
# LLM_MODEL="deepseek-chat"

TAVILY_API_KEY="your-tavily-api-key-here"

# Tushare is a free and open-source financial data platform for China. You can get your token from https://tushare.pro/register?reg=1
# Requires at least a Tushare Pro account to use the Tushare API. Please visit https://tushare.pro/register?reg=1 to register and obtain your token.
# And a minimum of 2000 points is required.
TUSHARE_TOKEN="your-tushare-token-here" 

# Langfuse configuration
LANGFUSE_SECRET_KEY="your-langfuse-secret-key-here"
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key-here"
LANGFUSE_BASE_URL="http://localhost:3001"
